program bsort;

    procedure BubbleSort (var x : array of integer; n : integer);
        var i       : integer;
            changed : boolean;

        procedure swap (var x, y : integer);
            var t : integer;
        begin
            t := x;
        x := y;
        y := t
        end;

    begin
        changed := true;
        while changed do
        begin
            i := 0;
            changed := false;
            while i < n-1 do
            begin
            if x[i] > x[i+1] then
            begin
                swap(x[i], x[i+1]);
                changed := true
            end;
            i := i+1
            end
        end
    end;